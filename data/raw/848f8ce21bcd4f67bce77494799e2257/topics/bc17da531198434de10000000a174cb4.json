cal-align:top;\" headers=\"d587481e375 \"><p class=\"p\"> 100\n</p></td><td class=\"entry\" style=\"vertical-align:top;\"></td></tr><tr class=\"row\"><td class=\"entry\" style=\"vertical-align:top;\" headers=\"d587481e363 d587481e371 \"></td><td class=\"entry\" style=\"vertical-align:top;\" headers=\"d587481e367 \"><p class=\"p\"> MM1301-\n</p></td><td class=\"entry\" colspan=\"2\" style=\"vertical-align:top;\" headers=\"d587481e367 \"><p class=\"p\"> Charges\n</p></td><td class=\"entry\" style=\"vertical-align:top;\" headers=\"d587481e375 \"><p class=\"p\"> 1.2\n</p></td><td class=\"entry\" style=\"vertical-align:top;\"><p class=\"p\"> 12/31/05\n</p></td></tr><tr class=\"row\"><td class=\"entry\" style=\"vertical-align:top;\" headers=\"d587481e363 d587481e371 \"><p class=\"p\"> 01/15/2005\n</p></td><td class=\"entry\" style=\"vertical-align:top;\" headers=\"d587481e367 \"><p class=\"p\"> AD1004\n</p></td><td class=\"entry\" colspan=\"2\" style=\"vertical-align:top;\" headers=\"d587481e367 \"><p class=\"p\"> Accrual (revenue)\n</p></td><td class=\"entry\" style=\"vertical-align:top;\" headers=\"d587481e375 \"><p class=\"p\"> 5\n</p></td><td class=\"entry\" style=\"vertical-align:top;\"></td></tr><tr class=\"row\"><td class=\"entry\" style=\"vertical-align:top;\" headers=\"d587481e363 d587481e371 \"></td><td class=\"entry\" style=\"vertical-align:top;\" headers=\"d587481e367 \"><p class=\"p\"> AD1015\n</p></td><td class=\"entry\" colspan=\"2\" style=\"vertical-align:top;\" headers=\"d587481e367 \"><p class=\"p\"> Deferral (expense)\n</p></td><td class=\"entry\" style=\"vertical-align:top;\" headers=\"d587481e375 \"><p class=\"p\"> 0.05\n</p></td><td class=\"entry\" style=\"vertical-align:top;\"></td></tr><tr class=\"row\"><td class=\"entry\" rowspan=\"3\" style=\"vertical-align:top;\" headers=\"d587481e363 d587481e371 \"><p class=\"p\"> 01/31/2005\n</p></td><td class=\"entry\" style=\"vertical-align:top;\" headers=\"d587481e367 \"><p class=\"p\"> MM1106+\n</p></td><t