86%\"><col width=\"14.285714285714286%\"></colgroup><thead class=\"thead\" style=\"text-align:left;\">\n<tr class=\"row\">\n<th class=\"entry\" style=\"vertical-align:top;\" id=\"d629512e801\"><p>Valuation Step</p></th>\n<th class=\"entry\" style=\"vertical-align:top;\" id=\"d629512e804\"><p>Dates</p></th>\n<th class=\"entry\" style=\"vertical-align:top;\" id=\"d629512e807\"><p>Rates</p></th>\n<th class=\"entry\" style=\"vertical-align:top;\" id=\"d629512e810\"><p>Amount in PC</p></th>\n<th class=\"entry\" style=\"vertical-align:top;\" id=\"d629512e813\"><p>Amount in VC</p></th>\n<th class=\"entry\" style=\"vertical-align:top;\" id=\"d629512e817\"><p>Remarks</p></th>\n<th class=\"entry\" style=\"vertical-align:top;\" id=\"d629512e820\"><p>Update Type</p></th>\n</tr>\n</thead><tbody class=\"tbody\">\n<tr class=\"row\">\n<td class=\"entry\" style=\"vertical-align:top;\" headers=\"d629512e801 \"><p class=\"p\">Rate valuation for forward exchange transactions (with the\nsetting spot/spot)</p></td>\n<td class=\"entry\" style=\"vertical-align:top;\" headers=\"d629512e804 \"><p class=\"p\">Contract date 12/1/2020</p></td>\n<td class=\"entry\" style=\"vertical-align:top;\" headers=\"d629512e807 \"><p class=\"p\">Spot rate 1.11</p></td>\n<td class=\"entry\" style=\"vertical-align:top;\" headers=\"d629512e810 \"><p class=\"p\">1,000,000.00 USD</p></td>\n<td class=\"entry\" style=\"vertical-align:top;\" headers=\"d629512e813 \"><p class=\"p\">900,900.90 EUR</p></td>\n<td class=\"entry\" style=\"vertical-align:top;\" headers=\"d629512e817 \">&nbsp;</td>\n<td class=\"entry\" style=\"vertical-align:top;\" headers=\"d629512e820 \">&nbsp;</td>\n</tr>\n<tr class=\"row\">\n<td class=\"entry\" style=\"vertical-align:top;\" headers=\"d629512e801 \">&nbsp;</td>\n<td class=\"entry\" style=\"vertical-align:top;\" headers=\"d629512e804 \"><p class=\"p\">Key date 01/31/2021 </p></td>\n<td class=\"entry\" style=\"vertical-align:top;\" headers=\"d629512e807 \"><p class=\"p\">Spot rate 1.15</p