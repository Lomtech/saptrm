  "body_html": "<!DOCTYPE html\n  SYSTEM \"about:legacy-compat\">\n<html lang=\"en-us\" dir=\"ltr\"><head><title>Display Payment Schedules</title><meta charset=\"utf-8\"><link rel=\"stylesheet\" type=\"text/css\" media=\"screen,projection\" href=\"/resource/css/style-v2.css\"><script type=\"text/javascript\" src=\"js/sap-strings.js\"></script></head><body class=\"en-us sap-light centered navigation-default enumeration-disabled\"><div id=\"d4h5-main-container\" class=\"container_12\" role=\"application\"><div id=\"d4h5-section-container\" class=\"grid_12\"><div id=\"d4h5-main-content\" class=\"grid_8 alpha omega\"><section><div class=\"page topic  - topic-topic \" id=\"loio5718da531198434de10000000a174cb4\"><h1 class=\"title topictitle1\">Display Payment Schedules</h1><div class=\"body\">\n<p class=\"p\"><span class=\"ph emphasis emphasis\">App ID</span>: <span class=\"ph sap-technical-name sap-technical-name\">TJ04</span></p>\n<div class=\"section section_pfdb use\">\n<p class=\"p\">With this app, you can display a comprehensive list of all treasury-related payments that\nhave been made or that are still due. The list also contains information about the business\npartners and bank details. </p>\n</div>\n<div class=\"section section_pfdb features\"><section class=\"section section_pfdb features\" type=\"Key Features\"><h2 class=\"section_title\">Key Features</h2>\n\n<p class=\"p\">This app provides the following key features:</p>\n<ul class=\"ul\" id=\"loio5718da531198434de10000000a174cb4__ul_gjr_mlk_y3b\">\n<li class=\"li\"><p class=\"p\">Display a list of payments across the Treasury component</p></li>\n<li class=\"li\"><p class=\"p\">Define the layout of the payment schedule by choosing and arranging report columns</p></li>\n<li class=\"li\"><p class=\"p\">Save your selection criteria as a variant</p></li>\n<li class=\"li\"><p class=\"p\">Export the list of payments to a spreadsheet</p></li>\n</ul>\n</section></div>\n<div class=\"section\"><section class=\"section\" type=\"Procedure\"><h2 class=\"section_title\">Procedure</h2>\n\n<ol class=\"ol\">\n<li class=\"li\"><p class=\"p\">Open the <span class=\"ph uicontrol\">Display Payment Schedules</span> app on the SAP Fiori\nlaunchpad.</p></li>\n<li class=\"li\"><p class=\"p\">The <span class=\"ph uicontrol\">Treasury: Payment Schedule</span> screen appears. Enter your\nselection criteria in the corresponding fields. </p></li>\n<li class=\"li\"><p class=\"p\">Choose <span class=\"ph uicontrol\">Execute</span>. A list appears displaying payments with business\npartner information and the bank details used for processing.</p></li>\n</ol>\n</section></div>\n<div class=\"section\" id=\"loio5718da531198434de10000000a174cb4__section_uwl_zbn_dtb\"><section class=\"section\" type=\"Supported Device Types\"><h2 class=\"section_title\">Supported Device Types</h2>\n\n<ul class=\"ul\" id=\"loio5718da531198434de10000000a174cb4__d7e1129\">\n<li class=\"li\"><p class=\"p\">Desktop</p></li>\n<li class=\"li\"><p class=\"p\">Tablet</p></li>\n</ul>\n</section></div>\n</div></div></section><div class=\"clear\"></div>\n</div></div></div></body></html>"
}