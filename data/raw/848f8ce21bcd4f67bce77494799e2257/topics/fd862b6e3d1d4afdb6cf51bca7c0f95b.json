  "body_html": "<!DOCTYPE html\n  SYSTEM \"about:legacy-compat\">\n<html lang=\"en-us\" dir=\"ltr\"><head><title>Display Financial Transactions with Changed Counterparty</title><meta charset=\"utf-8\"><link rel=\"stylesheet\" type=\"text/css\" media=\"screen,projection\" href=\"/resource/css/style-v2.css\"><script type=\"text/javascript\" src=\"js/sap-strings.js\"></script></head><body class=\"en-us sap-light centered navigation-default enumeration-disabled\"><div id=\"d4h5-main-container\" class=\"container_12\" role=\"application\"><div id=\"d4h5-section-container\" class=\"grid_12\"><div id=\"d4h5-main-content\" class=\"grid_8 alpha omega\"><section><div class=\"page concept  - topic-topic concept-concept \" id=\"loiofd862b6e3d1d4afdb6cf51bca7c0f95b\"><h1 class=\"title topictitle1\">Display Financial Transactions with Changed Counterparty</h1><div class=\"body conbody\">\n<div class=\"section\"><section class=\"section\" type=\"Use\"><h2 class=\"section_title\">Use</h2><p class=\"p\">You can use this program to display all financial transactions for which the counterparty has changed.\n</p>\n<p class=\"p\">The results list contains the financial transaction number and data relating to the financial transaction, the new partner, the previous partner, and the change date.\n</p>\n<p class=\"p\">The list is issued using the <a class=\"xref\" href=\"4dd40b7ac2234be2e10000000a42189c.html\" title=\"\">SAP List Viewer for SAP GUI (Classic)</a>.\n</p>\n</section></div>\n<div class=\"section\"><section class=\"section\" type=\"More Information\"><h2 class=\"section_title\">More Information</h2><p class=\"p\"><a class=\"xref\" href=\"7b9aecdd2bcf4c3f8f9be9db2cd1e197.html\">Change Counterparties for Financial Transactions</a>\n</p>\n</section></div>\n</div></div></section><div class=\"clear\"></div>\n</div></div></div></body></html>"
