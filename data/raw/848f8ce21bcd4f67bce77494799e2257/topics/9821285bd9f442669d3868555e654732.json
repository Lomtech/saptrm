ass=\"entry\" style=\"vertical-align:top;\"><p class=\"p\"> X\n</p></td><td class=\"entry\" style=\"vertical-align:top;\"><p class=\"p\"> X\n</p></td><td class=\"entry\" style=\"vertical-align:top;\"><p class=\"p\"> X\n</p></td></tr><tr class=\"row\"><td class=\"entry\" style=\"vertical-align:top;\"><p class=\"p\"> Payment details ID\n</p></td><td class=\"entry\" style=\"vertical-align:top;\"><p class=\"p\"> X\n</p></td><td class=\"entry\" style=\"vertical-align:top;\"><p class=\"p\"> X\n</p></td><td class=\"entry\" style=\"vertical-align:top;\"><p class=\"p\"> X\n</p></td><td class=\"entry\" style=\"vertical-align:top;\"><p class=\"p\"> X\n</p></td></tr><tr class=\"row\"><td class=\"entry\" style=\"vertical-align:top;\"><p class=\"p\"> House bank\n</p></td><td class=\"entry\" style=\"vertical-align:top;\"><p class=\"p\"> O\n</p></td><td class=\"entry\" style=\"vertical-align:top;\"><p class=\"p\"> O\n</p></td><td class=\"entry\" style=\"vertical-align:top;\"><p class=\"p\"> O\n</p></td><td class=\"entry\" style=\"vertical-align:top;\"><p class=\"p\"> O\n</p></td></tr><tr class=\"row\"><td class=\"entry\" style=\"vertical-align:top;\"><p class=\"p\"> Account ID\n</p></td><td class=\"entry\" style=\"vertical-align:top;\"><p class=\"p\"> O\n</p></td><td class=\"entry\" style=\"vertical-align:top;\"><p class=\"p\"> O\n</p></td><td class=\"entry\" style=\"vertical-align:top;\"><p class=\"p\"> O\n</p></td><td class=\"entry\" style=\"vertical-align:top;\"><p class=\"p\"> O\n</p></td></tr><tr class=\"row\"><td class=\"entry\" style=\"vertical-align:top;\"><p class=\"p\"> Payment transaction\n</p></td><td class=\"entry\" style=\"vertical-align:top;\"></td><td class=\"entry\" style=\"vertical-align:top;\"></td><td class=\"entry\" style=\"vertical-align:top;\"><p class=\"p\"> X\n</p></td><td class=\"entry\" style=\"vertical-align:top;\"><p class=\"p\"> X\n</p></td></tr><tr class=\"row\"><td class=\"entry\" style=\"vertical-align:top;\"><p class=\"p\"> Payer/payee\n</p></td><t