  "body_html": "<!DOCTYPE html\n  SYSTEM \"about:legacy-compat\">\n<html lang=\"en-us\" dir=\"ltr\"><head><title>Manage Trader Authorizations</title><meta charset=\"utf-8\"><link rel=\"stylesheet\" type=\"text/css\" media=\"screen,projection\" href=\"/resource/css/style-v2.css\"><script type=\"text/javascript\" src=\"js/sap-strings.js\"></script></head><body class=\"en-us sap-light centered navigation-default enumeration-disabled\"><div id=\"d4h5-main-container\" class=\"container_12\" role=\"application\"><div id=\"d4h5-section-container\" class=\"grid_12\"><div id=\"d4h5-main-content\" class=\"grid_8 alpha omega\"><section><div class=\"page topic  - topic-topic \" id=\"loio0b0eda531198434de10000000a174cb4\"><h1 class=\"title topictitle1\">Manage Trader Authorizations </h1><div class=\"body\">\n<p class=\"p\"><span class=\"ph emphasis emphasis\">App ID</span>: <span class=\"ph sap-technical-name sap-technical-name\">TBT1</span></p>\n<div class=\"section section_pfdb use\">\n<p class=\"p\">With this app, you can restrict the financial transactions a trader may conclude to\nthe individual values of the following fields:</p>\n<ul class=\"ul\">\n<li class=\"li\"><p class=\"p\">Contract types</p></li>\n<li class=\"li\"><p class=\"p\">Product categories</p></li>\n<li class=\"li\"><p class=\"p\">Product types</p></li>\n<li class=\"li\"><p class=\"p\">Transaction types</p></li>\n</ul>\n<aside class=\"note\" aria-labelledby=\"n0t\"><div class=\"title\" id=\"n0t\"><strong>Note</strong></div>\n<p class=\"p\">The authorization at a higher level automatically includes the levels below\nit.</p></aside>\n</div>\n<div class=\"section\"><section class=\"section\" type=\"Prerequisites\"><h2 class=\"section_title\">Prerequisites</h2>\n\n<p class=\"p\">You have defined the traders in the <a class=\"xref\" href=\"09bc501a83ef466b9df1adb8e5275431.html\">Define Traders</a> app.</p>\n</section></div>\n<div class=\"section\" id=\"loio0b0eda531198434de10000000a174cb4__section_blk_4rh_dtb\"><section class=\"section\" type=\"Supported Device Types\"><h2 class=\"section_title\">Supported Device Types</h2>\n\n<ul class=\"ul\" id=\"loio0b0eda531198434de10000000a174cb4__d7e1129\">\n<li class=\"li\"><p class=\"p\">Desktop</p></li>\n<li class=\"li\"><p class=\"p\">Tablet</p></li>\n</ul>\n</section></div>\n</div></div></section><div class=\"clear\"></div>\n</div></div></div></body></html>"
}