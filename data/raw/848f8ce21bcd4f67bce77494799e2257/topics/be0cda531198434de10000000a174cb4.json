  "body_html": "<!DOCTYPE html\n  SYSTEM \"about:legacy-compat\">\n<html lang=\"en-us\" dir=\"ltr\"><head><title>Example: Valuation Case 5</title><meta charset=\"utf-8\"><link rel=\"stylesheet\" type=\"text/css\" media=\"screen,projection\" href=\"/resource/css/style-v2.css\"><script type=\"text/javascript\" src=\"js/sap-strings.js\"></script></head><body class=\"en-us sap-light centered navigation-default enumeration-disabled\"><div id=\"d4h5-main-container\" class=\"container_12\" role=\"application\"><div id=\"d4h5-section-container\" class=\"grid_12\"><div id=\"d4h5-main-content\" class=\"grid_8 alpha omega\"><section><div class=\"page topic  - topic-topic \" id=\"loiobe0cda531198434de10000000a174cb4\"><h1 class=\"title topictitle1\">Example: Valuation Case 5 </h1><div class=\"body\">\n<p class=\"p\"><span class=\"ph emphasis emphasis\">Basic Data Case 5:</span>\n</p>\n<ul class=\"ul\"><li class=\"li\"><p class=\"p\"> OCI (H-GAAP) &lt; 0\n</p></li><li class=\"li\"><p class=\"p\"> VAD &lt; 0\n</p></li><li class=\"li\"><p class=\"p\"> VAD &gt; OCI (H-GAAP)\n</p></li></ul>\n<p class=\"p\"><span class=\"ph emphasis emphasis\">Example Data:</span>\n</p>\n<ul class=\"ul\"><li class=\"li\"><p class=\"p\"> VAD = - 10 UNI\n</p></li><li class=\"li\"><p class=\"p\"> Unrealized gains (before valuation) = 15 UNI\n</p></li><li class=\"li\"><p class=\"p\"> Valuation at market price of 92 UNI, means unrealized losses of 8 UNI\n</p><div class=\"table-wrapper tablenoborder\"><table summary=\"\" class=\"table\" frame=\"border\" border=\"1\" rules=\"all\"><colgroup><col width=\"12.5%\"><col width=\"12.5%\"><col width=\"12.5%\"><col width=\"12.5%\"><col width=\"12.5%\"><col width=\"12.5%\"><col width=\"12.5%\"><col width=\"12.5%\"></colgroup><thead class=\"thead\" style=\"text-align:left;\"><tr class=\"row\"><th class=\"entry\" rowspan=\"2\" style=\"vertical-align:top;\" id=\"d646831e108\"><p class=\"p\"> Position components\n</p></th><th class=\"entry\" style=\"vertical-align:top;\