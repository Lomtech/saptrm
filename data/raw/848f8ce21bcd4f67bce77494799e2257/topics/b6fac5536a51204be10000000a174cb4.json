  "body_html": "<!DOCTYPE html\n  SYSTEM \"about:legacy-compat\">\n<html lang=\"en-us\" dir=\"ltr\"><head><title>Product Groups</title><meta charset=\"utf-8\"><link rel=\"stylesheet\" type=\"text/css\" media=\"screen,projection\" href=\"/resource/css/style-v2.css\"><script type=\"text/javascript\" src=\"js/sap-strings.js\"></script></head><body class=\"en-us sap-light centered navigation-default enumeration-disabled\"><div id=\"d4h5-main-container\" class=\"container_12\" role=\"application\"><div id=\"d4h5-section-container\" class=\"grid_12\"><div id=\"d4h5-main-content\" class=\"grid_8 alpha omega\"><section><div class=\"page topic  - topic-topic \" id=\"loiob6fac5536a51204be10000000a174cb4\"><h1 class=\"title topictitle1\">Product Groups </h1><div class=\"body\">\n<p class=\"p\"> The selection of product groups only includes positions of the respective relevant contract types.\n</p>\n<ul class=\"ul\"><li class=\"li\"><p class=\"p\"><span class=\"ph uicontrol\"> Securities</span> (= contract type 2)\n</p></li><li class=\"li\"><p class=\"p\"><span class=\"ph uicontrol\"> Loans</span> (= contract type 1)\n</p></li><li class=\"li\"><p class=\"p\"><span class=\"ph uicontrol\"> OTC transactions</span> (= contract types 4, 5, and 6)\n</p><p class=\"p\"> Exceptions:\n</p><p class=\"p\"> Product categories 700 - 750\n</p></li><li class=\"li\"><p class=\"p\"><span class=\"ph uicontrol\"> Listed derivatives</span> (= contract type 6)\n</p><p class=\"p\"> Only product categories 700 - 750\n</p></li></ul>\n</div></div></section><div class=\"clear\"></div>\n</div></div></div></body></html>"
