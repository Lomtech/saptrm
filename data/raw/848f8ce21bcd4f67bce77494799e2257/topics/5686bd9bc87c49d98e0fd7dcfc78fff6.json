  "body_html": "<!DOCTYPE html\n  SYSTEM \"about:legacy-compat\">\n<html lang=\"en-us\" dir=\"ltr\"><head><title>Reverse Account Assignment Transfer</title><meta charset=\"utf-8\"><link rel=\"stylesheet\" type=\"text/css\" media=\"screen,projection\" href=\"/resource/css/style-v2.css\"><script type=\"text/javascript\" src=\"js/sap-strings.js\"></script></head><body class=\"en-us sap-light centered navigation-default enumeration-disabled\"><div id=\"d4h5-main-container\" class=\"container_12\" role=\"application\"><div id=\"d4h5-section-container\" class=\"grid_12\"><div id=\"d4h5-main-content\" class=\"grid_8 alpha omega\"><section><div class=\"page concept  - topic-topic concept-concept \" id=\"loio5686bd9bc87c49d98e0fd7dcfc78fff6\"><h1 class=\"title topictitle1\">Reverse Account Assignment Transfer</h1><div class=\"body conbody\">\n<div class=\"section section_pfdb use\">\n<p class=\"p\">You use this app to reverse an account assignment transfer.</p>\n<p class=\"p\">For more information, see also <a class=\"xref\" href=\"3a59393494a14c4da2f5247b2f4ee7b2.html\">Account Assignment Transfer</a>.</p>\n</div>\n<div class=\"section\" id=\"loio5686bd9bc87c49d98e0fd7dcfc78fff6__section_tgb_w21_npb\"><section class=\"section\" type=\"Activities\"><h2 class=\"section_title\">Activities</h2>\n\n<ol class=\"ol\" id=\"loio5686bd9bc87c49d98e0fd7dcfc78fff6__ol_nbv_y21_npb\">\n<li class=\"li\"><p class=\"p\">Specify a product group.</p></li>\n<li class=\"li\"><p class=\"p\">Specify the key date of the account assignment transfer to be reversed.</p></li>\n<li class=\"li\"><p class=\"p\">Specify the reason for reversal.</p></li>\n<li class=\"li\"><p class=\"p\">You can enter a specific FI reversal date or FI reversal period.</p></li>\n<li class=\"li\"><p class=\"p\">You can run the account assignment transfer as a test run.</p></li>\n<li class=\"li\"><p class=\"p\">Run the report.</p></li>\n<li class=\"li\"><p class=\"p\">The system displays the selected transfers instead of the positions. </p></li>\n<li class=\"li\"><p class=\"p\">Perform the reversal.</p></li>\n</ol>\n</section></div>\n<div class=\"section\" id=\"loio5686bd9bc87c49d98e0fd7dcfc78fff6__section_jhy_w21_npb\"><section class=\"section\" type=\"Result\"><h2 class=\"section_title\">Result</h2>\n\n<p class=\"p\">The account assignment transfer is reversed.</p>\n</section></div>\n</div></div></section><div class=\"clear\"></div>\n</div></div></div></body></html>"
}