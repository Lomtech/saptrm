  "body_html": "<!DOCTYPE html\n  SYSTEM \"about:legacy-compat\">\n<html lang=\"en-us\" dir=\"ltr\"><head><title>Displaying a Hedging Area Version</title><meta charset=\"utf-8\"><link rel=\"stylesheet\" type=\"text/css\" media=\"screen,projection\" href=\"/resource/css/style-v2.css\"><script type=\"text/javascript\" src=\"js/sap-strings.js\"></script></head><body class=\"en-us sap-light centered navigation-default enumeration-disabled\"><div id=\"d4h5-main-container\" class=\"container_12\" role=\"application\"><div id=\"d4h5-section-container\" class=\"grid_12\"><div id=\"d4h5-main-content\" class=\"grid_8 alpha omega\"><section><div class=\"page task  - topic-topic task-task \" id=\"loioc9705758eab99344e10000000a4450e5\"><h1 class=\"title topictitle1\">Displaying a Hedging Area Version</h1><div class=\"body taskbody\"><p class=\"shortdesc\"></p><section class=\"section procedure\"><span id=\"steps\" class=\"anchor\"></span><div class=\"ol steps tasklabel\"><h2 class=\"sectiontitle tasklabel\">Procedure</h2></div><ol class=\"ol steps\"><li class=\"li step stepexpand\"><span class=\"ph cmd\">Call the function <span class=\"ph uicontrol\">Define Hedging Areas</span> (transaction <span class=\"ph sap-technical-name sap-technical-name\">TOE_HEDGING_AREA</span>) from the area menu of <span class=\"ph uicontrol\">Treasury and Risk Management</span> under <span class=\"ph menucascade\"><img src=\"themes/sap-light/img/navstart.gif\" alt=\"Start of the navigation path\" title=\"Start of the navigation path\"><span class=\"ph uicontrol\">Hedge Management and Accounting</span>&nbsp;<img src=\"themes/sap-light/img/navstep.gif\" alt=\"Next navigation step\" title=\"Next navigation step\">&nbsp;<span class=\"ph uicontrol\">Hedge Management</span>&nbsp;<img src=\"themes/sap-light/img/navstep.gif\" alt=\"Next navigation step\" title=\"Next navigation step\">&nbsp;<span class=\"ph uicontrol\">Master Data </span><img src=\"themes/sap-light/img/navend.gif\" alt=\"End of the navigation path\" title=\"End of the navigation path\"></span>.</span></li><li class=\"li step stepexpand\"><span class=\"ph cmd\">Enter an ID for the hedging area (not exceeding six digits).</span></li><li class=\"li step stepexpand\"><span class=\"ph cmd\">Choose the version.</span></li><li class=\"li step stepexpand\"><span class=\"ph cmd\">Choose <span class=\"ph uicontrol\">Display</span>.</span></li><li class=\"li step stepexpand\"><span class=\"ph cmd\">On the <span class=\"ph uicontrol\">Version History</span> tab, you can see all versions of the hedging area. The following data of the versions is displayed:</span><div class=\"itemgroup info\"><ul class=\"ul\"><li class=\"li\"><p class=\"p\">Valid-From Date</p></li><li class=\"li\"><p class=\"p\">Entered On</p></li><li class=\"li\"><p class=\"p\">Time of Initial Entry</p></li><li class=\"li\"><p class=\"p\">Entered By</p></li><li class=\"li\"><p class=\"p\">Last Edited On (Date)</p></li><li class=\"li\"><p class=\"p\">Last Edited At (Time)</p></li><li class=\"li\"><p class=\"p\">Last Changed By</p></li><li class=\"li\"><p class=\"p\">Memo</p></li></ul></div></li></ol></section></div></div></section><div class=\"clear\"></div>\n</div></div></div></body></html>"
}