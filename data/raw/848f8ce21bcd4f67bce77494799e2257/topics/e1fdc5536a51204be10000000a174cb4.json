  "body_html": "<!DOCTYPE html\n  SYSTEM \"about:legacy-compat\">\n<html lang=\"en-us\" dir=\"ltr\"><head><title>Fixed-Term Deposit</title><meta charset=\"utf-8\"><link rel=\"stylesheet\" type=\"text/css\" media=\"screen,projection\" href=\"/resource/css/style-v2.css\"><script type=\"text/javascript\" src=\"js/sap-strings.js\"></script></head><body class=\"en-us sap-light centered navigation-default enumeration-disabled\"><div id=\"d4h5-main-container\" class=\"container_12\" role=\"application\"><div id=\"d4h5-section-container\" class=\"grid_12\"><div id=\"d4h5-main-content\" class=\"grid_8 alpha omega\"><section><div class=\"page topic  - topic-topic \" id=\"loioe1fdc5536a51204be10000000a174cb4\"><h1 class=\"title topictitle1\">Fixed-Term Deposit </h1><div class=\"body\">\n<p class=\"p\"> Nominal amount: EUR 2,000,000.00\n</p>\n<p class=\"p\"> Term: 12/13/2000 – 12/13/2002\n</p>\n<p class=\"p\"> Nominal interest rate: 4%\n</p>\n<p class=\"p\"> Interest calculation method: 360/360\n</p>\n<p class=\"p\"> Interest payment cycle: every 12 months\n</p>\n<p class=\"p\"> Cash flow:\n</p>\n<div class=\"table-wrapper tablenoborder\"><table summary=\"\" class=\"table\" frame=\"border\" border=\"1\" rules=\"all\"><colgroup><col width=\"33.333333333333336%\"><col width=\"33.333333333333336%\"><col width=\"33.333333333333336%\"></colgroup><thead class=\"thead\" style=\"text-align:left;\"><tr class=\"row\"><th class=\"entry\" style=\"vertical-align:top;\" id=\"d199236e86\"><p class=\"p\"> Payment date\n</p></th><th class=\"entry\" style=\"vertical-align:top;\" id=\"d199236e90\"><p class=\"p\"> Payment amount\n</p></th><th class=\"entry\" style=\"vertical-align:top;\" id=\"d199236e94\"><p class=\"p\"> Type of flow\n</p></th></tr></thead><tbody class=\"tbody\"><tr class=\"row\"><td class=\"entry\" style=\"vertical-align:top;\" headers=\"d199236e86 \"><p class=\"p\"> 12/13/2000\n</p></td><td class=\"entry\" style=\"vertical-align:top;\" headers=\"d199236e90 \"><p class=\"p\"> EUR